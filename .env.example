# Example environment variables for AssistenteNovo
# Copy to .env and update values for your environment

# Django
SECRET_KEY=please-change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres) - if empty, sqlite is used
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# S3 toggle and credentials
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
