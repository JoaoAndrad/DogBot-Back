NODE_ENV=development
PORT=80

# Base connection string without ssl params; P12 will be appended at runtime if P12_PASSWORD is set
DATABASE_URL='postgresql://squarecloud:104n8Pxn9Dc2cWxmbToxGyLq@square-cloud-db-e09d8da7cd3d4752bf3b0e4b9c0792d0.squareweb.app:7112/dogbot_db?sslidentity=./certs/client-identity.p12&sslpassword=andrade'

# Password used to unlock client-identity.p12 (export password)
P12_PASSWORD=andrade

# Optional: if you prefer to provide the .p12 via env var instead of shipping file, paste base64 here
#PRISMA_P12_BASE64=

JWT_SECRET=changeme
BOT_SECRET=changeme
INTERNAL_API_SECRET=changeme
LOG_LEVEL=info

# Admin UI credentials (change in production)
ADMIN_USER=admin
ADMIN_PASS=changeme
# Session secret used by AdminJS auth cookie
SESSION_SECRET=change_this_session_secret

# Paths used by libpq (psql / Prisma CLI) to load client certs (use relative paths from backend root)
# These help `npx prisma db pull` and `psql` when run from the backend folder.
# In production the app exposes certs under /application/prisma/certs — prefer absolute paths
PGSSLCERT=./certificados/client-cert.pem
PGSSLKEY=./certificados/client-key.pem
# No CA required for this setup; leave PGSSLROOTCERT empty or remove if not used
# PGSSLROOTCERT=./certificados/ca.pem
PRISMA_LOG_LEVEL=debug
