NODE_ENV=production
PORT=80

# Base connection string without ssl params; P12 will be appended at runtime if P12_PASSWORD is set
# TEMPORÁRIO: Caminho absoluto Windows para migrações (REVERTER DEPOIS!)
#DATABASE_URL='postgresql://squarecloud:9ySOoBFExYWNROPOnQtdLw7k@square-cloud-db-e3dc24518aa9456caa8de928c2083e0d.squareweb.app:7150/backend?sslidentity=S:/DogBotReborn/backend/prisma/certs/client-identity.p12&sslpassword=andrade'
# PRODUÇÃO: Caminho relativo (descomentar depois das migrações)
DATABASE_URL='postgresql://squarecloud:9ySOoBFExYWNROPOnQtdLw7k@square-cloud-db-e3dc24518aa9456caa8de928c2083e0d.squareweb.app:7150/backend?sslidentity=./prisma/certs/client-identity.p12&sslpassword=andrade'

# Password used to unlock client-identity.p12 (export password)
P12_PASSWORD=andrade

# Optional: if you prefer to provide the .p12 via env var instead of shipping file, paste base64 here
#PRISMA_P12_BASE64=

JWT_SECRET=changeme
BOT_SECRET=super-secret-value
INTERNAL_API_SECRET=super-secret-value
POLL_SHARED_SECRET=s3cr3t
LOG_LEVEL=info

# Admin UI credentials (change in production)
ADMIN_USER=admin
ADMIN_PASS=changeme
# Session secret used by AdminJS auth cookie
SESSION_SECRET=change_this_session_secret

# Paths used by libpq (psql / Prisma CLI) to load client certs (use relative paths from backend root)
# These help `npx prisma db pull` and `psql` when run from the backend folder.
# In production the app exposes certs under /application/prisma/certs — prefer absolute paths
PGSSLCERT=./prisma/certs/cert.pem
PGSSLKEY=./prisma/certs/key.pem
# No CA required for this setup; leave PGSSLROOTCERT empty or remove if not used
# PGSSLROOTCERT=./certificados/ca.pem
PRISMA_LOG_LEVEL=debug

