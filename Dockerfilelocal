FROM python:3.11-slim
WORKDIR /app
ENV PYTHONUNBUFFERED=1

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app

# copy and make entrypoint executable
COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
# Default to gunicorn for production-like behavior; respect $PORT (SquareCloud provides it)
CMD ["sh", "-lc", "if [ \"${DEV_AUTORELOAD:-0}\" = \"1\" ]; then python manage.py runserver 0.0.0.0:${PORT:-8000}; else gunicorn core.wsgi:application --bind 0.0.0.0:${PORT:-8000} --workers 3; fi"]
