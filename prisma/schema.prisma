generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// Poll created from frontend (native or fallback)
model Poll {
  id          String   @id
  chat_id     String
  title       String?
  // raw options array as provided by frontend
  options     Json?    @db.Json
  // richer option objects (local id, name, etc.)
  poll_options Json?   @db.Json
  // additional options object / metadata
  options_obj Json?    @db.Json
  type        String?  @default("native")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  votes       Vote[]
  @@map("Poll")
}

// A record representing a single vote for a Poll
model Vote {
  id               String   @id @default(uuid())
  poll_id          String
  voter_id         String
  // JSON blobs to allow flexible vote shapes from frontend
  selected_options Json?    @db.Json
  selected_indexes Json?    @db.Json
  selected_names   Json?    @db.Json
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  poll             Poll     @relation(fields: [poll_id], references: [id])
  @@index([poll_id])
  @@index([voter_id])
}

// Normalized message records forwarded from frontend
model Message {
  id           String   @id
  chat_id      String
  from_id      String?
  display_name String?
  is_group     Boolean  @default(false)
  body         String?
  snippet      String?
  has_media    Boolean  @default(false)
  media_meta   Json?    @db.Json
  msg_type     String?
  received_at  DateTime @default(now()) @db.Timestamptz(6)
  origin       String?  @default("whatsapp-frontend")
}

// User model to centralize user data collected from WhatsApp and other sources
model User {
  id                 String   @id @default(uuid())
  sender_number      String   @unique
  identifiers        String[]
  display_name       String?
  push_name          String?
  push_name_history  Json?    @db.Json
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  last_seen          DateTime? @db.Timestamptz(6)
  last_group_activity DateTime? @db.Timestamptz(6)
  last_known_lid     String?
  confissoes         Json?    @db.Json
  metadata           Json?    @db.Json

  // relations
  pushNameHistory    PushNameHistory[]
  // DogFort/Academia stats (one-to-one)
  dogfort            DogFortStats?

  @@map("User")
}

model PushNameHistory {
  id            String   @id @default(uuid())
  user_id       String
  observed_from String?
  observed_lid  String?
  push_name     String
  ts            BigInt?  @db.BigInt

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
}

// DogFort (academia) stats tied to a user. Kept separate for scalability.
model DogFortStats {
  id         String   @id @default(uuid())
  user_id    String   @unique
  saldo      Int?     @default(0)
  mensal     Int?     @default(0)
  anual      Int?     @default(0)
  trofeus    Int?     @default(0)
  ultimo_treino DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@map("DogFortStats")
}
