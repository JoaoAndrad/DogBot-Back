generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// Poll created from frontend (native or fallback)
model Poll {
  id          String   @id
  chat_id     String
  title       String?
  // raw options array as provided by frontend
  options     Json?    @db.Json
  // richer option objects (local id, name, etc.)
  poll_options Json?   @db.Json
  // additional options object / metadata
  options_obj Json?    @db.Json
  type        String?  @default("native")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  votes       Vote[]
  @@map("Poll")
}

// A record representing a single vote for a Poll
model Vote {
  id               String   @id @default(uuid())
  poll_id          String
  voter_id         String
  // JSON blobs to allow flexible vote shapes from frontend
  selected_options Json?    @db.Json
  selected_indexes Json?    @db.Json
  selected_names   Json?    @db.Json
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  poll             Poll     @relation(fields: [poll_id], references: [id])
  @@index([poll_id])
  @@index([voter_id])
}

// Normalized message records forwarded from frontend
model Message {
  id           String   @id
  chat_id      String
  from_id      String?
  display_name String?
  is_group     Boolean  @default(false)
  body         String?
  snippet      String?
  has_media    Boolean  @default(false)
  media_meta   Json?    @db.Json
  msg_type     String?
  received_at  DateTime @default(now()) @db.Timestamptz(6)
  origin       String?  @default("whatsapp-frontend")
}

// User model to centralize user data collected from WhatsApp and other sources
model User {
  id                 String   @id @default(uuid())
  sender_number      String   @unique
  identifiers        String[]
  display_name       String?
  push_name          String?
  push_name_history  Json?    @db.Json
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  last_seen          DateTime? @db.Timestamptz(6)
  last_group_activity DateTime? @db.Timestamptz(6)
  last_known_lid     String?
  confissoes         Json?    @db.Json
  metadata           Json?    @db.Json

  // relations
  pushNameHistory    PushNameHistory[]
  // DogFort/Academia stats (one-to-one)
  dogfort            DogFortStats?
  // Spotify relations
  spotifyAccounts    SpotifyAccount[]
  trackPlaybacks     TrackPlayback[]
  trackVotes         TrackVote[]
  trackNotes         TrackNote[]
  playlistEntriesAdded PlaylistEntry[]
  liveRequests       LiveRequest[]
  listeningSummary   UserListeningSummary?

  @@map("User")
}

model PushNameHistory {
  id            String   @id @default(uuid())
  user_id       String
  observed_from String?
  observed_lid  String?
  push_name     String
  ts            BigInt?  @db.BigInt

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
}

// DogFort (academia) stats tied to a user. Kept separate for scalability.
model DogFortStats {
  id         String   @id @default(uuid())
  user_id    String   @unique
  saldo      Int?     @default(0)
  mensal     Int?     @default(0)
  anual      Int?     @default(0)
  plan       String?
  meta_anual Int?
  trofeus    Int?     @default(0)
  ultimo_treino DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@map("DogFortStats")
}

// === Spotify models ===

model SpotifyAccount {
  id         String   @id @default(uuid())
  userId     String?  // optional FK to User.id for per-user tokens
  accountType String  @default("bot") // 'bot' | 'user'
  clientId   String?
  scope      String?
  meta       Json?    @db.Json
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  tokens     SpotifyToken[]
  playbacks  TrackPlayback[]
  // reverse relations
  user       User?     @relation(fields: [userId], references: [id])
  currentPlayback CurrentPlayback?

  // playlists and sessions managed by this account
  playlists  Playlist[]
  sessions   SpotifySession[]

  @@index([userId])
}

model SpotifyToken {
  id            String   @id @default(uuid())
  accountId     String
  accessToken   String
  refreshToken  String
  scope         String?
  expiresAt     DateTime?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  account       SpotifyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model Track {
  id         String   @id // Spotify track id
  name       String?
  artists    Json?    @db.Json
  album      String?
  durationMs Int?
  metadata   Json?    @db.Json

  playbacks  TrackPlayback[]
  stats      TrackStat?
  votes      TrackVote[]
  notes      TrackNote[]
  playlistEntries PlaylistEntry[]
  liveRequests LiveRequest[]

  @@map("Track")
}

model TrackPlayback {
  id         String   @id @default(uuid())
  accountId  String
  userId     String?
  trackId    String
  deviceId   String?
  contextType String?
  contextId  String?
  startedAt  DateTime @default(now()) @db.Timestamptz(6)
  endedAt    DateTime? @db.Timestamptz(6)
  listenedMs BigInt?  @db.BigInt
  percentPlayed Float?
  metadata   Json?    @db.Json

  account    SpotifyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  track      Track          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user       User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trackId, startedAt])
  @@index([userId])
}

model CurrentPlayback {
  accountId  String   @id
  trackId    String
  startedAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  metadata   Json?    @db.Json

  account    SpotifyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model TrackStat {
  trackId     String   @id
  playCount   Int      @default(0)
  totalListenMs BigInt @default(0) @db.BigInt
  avgSessionMs Int?
  lastPlayedAt DateTime? @db.Timestamptz(6)

  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([lastPlayedAt])
}

model UserListeningSummary {
  userId       String   @id
  totalListenMs BigInt  @default(0) @db.BigInt
  dailyListen  Json?    @db.Json
  lastUpdatedAt DateTime @updatedAt @db.Timestamptz(6)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrackVote {
  id           String   @id @default(uuid())
  trackId      String
  userId       String
  vote         Int
  contextId    String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([userId])
}

model TrackNote {
  id        String   @id @default(uuid())
  trackId   String
  userId    String
  note      String?  @db.Text
  rating    Int?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([userId])
}

model PlaylistEntry {
  id            String   @id @default(uuid())
  playlistId    String
  trackId       String
  addedByUserId String?
  addedAt       DateTime @default(now()) @db.Timestamptz(6)
  position      Int?
  metadata      Json?    @db.Json

  track         Track?   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  addedBy       User?    @relation(fields: [addedByUserId], references: [id], onDelete: Cascade)

  // Relacionamento com Playlist gerenciada
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([addedByUserId])
}

// =====================
// Spotify management models
// =====================

model Playlist {
  id         String   @id @default(uuid())
  name       String
  description String?
  spotifyId  String?  // optional external Spotify playlist id
  accountId  String?  // FK to SpotifyAccount when tied to a bot account
  coverUrl   String?
  isManaged  Boolean  @default(true)
  meta       Json?    @db.Json
  syncedAt   DateTime? @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  // relations
  entries    PlaylistEntry[]
  account    SpotifyAccount? @relation(fields: [accountId], references: [id])
  liveRequests LiveRequest[]
  syncLogs     PlaylistSyncLog[]

  @@index([accountId])
}

model LiveRequest {
  id                 String   @id @default(uuid())
  trackId            String?  // FK to Track (if resolved)
  userId             String?  // who requested (User.id)
  playlistId         String?  // optional target playlist
  status             String   @default("pending") // pending | approved | played | rejected
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  handledBySessionId String?
  handledAt          DateTime? @db.Timestamptz(6)
  metadata           Json?    @db.Json
  archivedAt         DateTime? @db.Timestamptz(6)

  // relations
  track    Track?   @relation(fields: [trackId], references: [id], onDelete: SetNull)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  playlist Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  session  SpotifySession? @relation(fields: [handledBySessionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
}

model SpotifySession {
  id         String   @id @default(uuid())
  accountId  String
  deviceId   String?
  startedAt  DateTime @default(now()) @db.Timestamptz(6)
  lastSeen   DateTime? @db.Timestamptz(6)
  isActive   Boolean  @default(true)
  metadata   Json?    @db.Json

  account    SpotifyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // requests handled by this session
  handledRequests LiveRequest[]

  @@index([accountId, isActive])
  @@index([lastSeen])
}

model PlaylistSyncLog {
  id          String   @id @default(uuid())
  playlistId  String
  attemptedBy String?  // user id who triggered sync
  startedAt   DateTime @default(now()) @db.Timestamptz(6)
  finishedAt  DateTime? @db.Timestamptz(6)
  success     Boolean? @default(false)
  result      Json?    @db.Json
  errorMessage String?

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([startedAt])
}

// Temporary OAuth session records for frontend-initiated Spotify auth flows
model SpotifyAuthSession {
  id            String   @id @default(uuid())
  state         String   @unique
  userId        String?  // optional: the local User.id this auth is intended for
  accountId     String?  // optional: SpotifyAccount.id if already known
  redirectAfter String?  // optional URL or route to redirect after auth
  used          Boolean  @default(false)
  metadata      Json?    @db.Json
  expiresAt     DateTime?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([accountId])
}

