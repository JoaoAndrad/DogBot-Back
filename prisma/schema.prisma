generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// Poll created from frontend (native or fallback)
model Poll {
  id          String   @id
  chat_id     String
  title       String?
  // raw options array as provided by frontend
  options     Json?    @db.Json
  // richer option objects (local id, name, etc.)
  poll_options Json?   @db.Json
  // additional options object / metadata
  options_obj Json?    @db.Json
  type        String?  @default("native")
  // metadata for flow navigation (flowId, path, etc.)
  metadata    Json?    @db.Json
  // Collaborative voting info
  vote_type   String?  // "add" or "skip"
  vote_id     String?  // ID of the associated CollaborativeVote
  group_id    String?  // ID of the group chat
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  votes       Vote[]
  collaborativeVotes CollaborativeVote[]
  @@map("Poll")
}

// A record representing a single vote for a Poll
model Vote {
  id               String   @id @default(uuid())
  poll_id          String
  voter_id         String
  // JSON blobs to allow flexible vote shapes from frontend
  selected_options Json?    @db.Json
  selected_indexes Json?    @db.Json
  selected_names   Json?    @db.Json
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  poll             Poll     @relation(fields: [poll_id], references: [id])
  @@index([poll_id])
  @@index([voter_id])
}

// Normalized message records forwarded from frontend
model Message {
  id           String   @id
  chat_id      String
  from_id      String?
  display_name String?
  is_group     Boolean  @default(false)
  body         String?
  snippet      String?
  has_media    Boolean  @default(false)
  media_meta   Json?    @db.Json
  msg_type     String?
  received_at  DateTime @default(now()) @db.Timestamptz(6)
  origin       String?  @default("whatsapp-frontend")
}

// User model to centralize user data collected from WhatsApp and other sources
model User {
  id                 String   @id @default(uuid())
  sender_number      String   @unique
  identifiers        String[]
  display_name       String?
  push_name          String?
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  last_seen          DateTime? @db.Timestamptz(6)
  last_group_activity DateTime? @db.Timestamptz(6)
  last_known_lid     String?
  confissoes         Json?    @db.Json
  // Confissões: saldo diário, última atualização e flag VIP (vitalício)
  confessions_balance Int      @default(5)
  confessions_last_update DateTime?
  confessions_vip     Boolean  @default(false)
  metadata           Json?    @db.Json
  // Admin flag for broadcast and privileged operations
  isAdmin            Boolean  @default(false)

  // relations
  pushNameHistory    PushNameHistory[]
  // DogFort/Academia stats (one-to-one)
  dogfort            DogFortStats?
  // Spotify relations
  spotifyAccounts    SpotifyAccount[]
  trackPlaybacks     TrackPlayback[]
  trackVotes         TrackVote[]
  trackNotes         TrackNote[]
  latestNotes        TrackNoteLatest[]
  playlistEntriesAdded PlaylistEntry[]
  liveRequests       LiveRequest[]
  listeningSummary   UserListeningSummary?
  yearSummaries      UserYearSummary[]
  listeningSessions  ListeningSession[]
  // Jam/Radio relations
  hostedJams         JamSession[]  @relation("JamHost")
  jamListenings      JamListener[]
  jamQueueEntries    JamQueue[]    @relation("JamQueueAdder")

  @@map("User")
}

model PushNameHistory {
  id            String   @id @default(uuid())
  user_id       String
  observed_from String?
  observed_lid  String?
  push_name     String
  ts            BigInt?  @db.BigInt

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
}

// DogFort (academia) stats tied to a user. Kept separate for scalability.
model DogFortStats {
  id         String   @id @default(uuid())
  user_id    String   @unique
  saldo      Int?     @default(0)
  mensal     Int?     @default(0)
  anual      Int?     @default(0)
  plan       String?
  meta_anual Int?
  trofeus    Int?     @default(0)
  ultimo_treino DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@map("DogFortStats")
}

// === Spotify models ===

model SpotifyAccount {
  id         String   @id @default(uuid())
  userId     String?  // optional FK to User.id for per-user tokens
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  lastDeviceId String? // cache last used Spotify device ID

  tokens     SpotifyToken[]
  playbacks  TrackPlayback[]
  // reverse relations
  user       User?     @relation(fields: [userId], references: [id])
  currentPlayback CurrentPlayback?

  // playlists managed by this account
  playlists  Playlist[]

  @@index([userId])
}

model SpotifyToken {
  id            String   @id @default(uuid())
  accountId     String
  accessToken   String
  refreshToken  String
  scope         String?
  expiresAt     DateTime?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)

  account       SpotifyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model Track {
  id         String   @id // Spotify track id
  name       String?
  artists    Json?    @db.Json
  album      String?
  durationMs Int?
  
  // Audio features for Wrapped insights
  genres     String[]
  audioFeatures Json? @db.Json // { danceability, energy, valence, tempo, ... }
  popularity Int?
  releaseDate String?
  imageUrl   String?
  
  metadata   Json?    @db.Json

  playbacks  TrackPlayback[]
  stats      TrackStat?
  votes      TrackVote[]
  notes      TrackNote[]
  latestNotes TrackNoteLatest[]
  playlistEntries PlaylistEntry[]
  liveRequests LiveRequest[]

  @@map("Track")
}

model TrackPlayback {
  id         String   @id @default(uuid())
  accountId  String
  userId     String?
  trackId    String
  
  // Context and device
  deviceId   String?
  deviceType String?
  contextType String?
  contextId  String?
  
  startedAt  DateTime @default(now()) @db.Timestamptz(6)
  endedAt    DateTime? @db.Timestamptz(6)
  listenedMs BigInt?  @db.BigInt
  percentPlayed Float?
  
  // Behavior tracking for Wrapped
  wasSkipped Boolean? @default(false)
  wasRepeated Boolean? @default(false)
  isFirstPlay Boolean? @default(false)
  sessionId  String?
  source     String?  @default("monitor") // "monitor" | "import" | "manual"
  
  metadata   Json?    @db.Json

  account    SpotifyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  track      Track          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user       User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    ListeningSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([trackId, startedAt])
  @@index([userId])
  @@index([sessionId])
}

model CurrentPlayback {
  accountId  String   @id
  trackId    String
  startedAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  metadata   Json?    @db.Json

  account    SpotifyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model TrackStat {
  trackId     String   @id
  playCount   Int      @default(0)
  totalListenMs BigInt @default(0) @db.BigInt
  avgSessionMs Int?
  lastPlayedAt DateTime? @db.Timestamptz(6)

  // Rating aggregates
  avgRating   Decimal? @db.Decimal(4,2)
  ratingCount Int      @default(0)

  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([lastPlayedAt])
}

model UserListeningSummary {
  userId       String   @id
  totalListenMs BigInt  @default(0) @db.BigInt
  dailyListen  Json?    @db.Json
  lastUpdatedAt DateTime @updatedAt @db.Timestamptz(6)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrackVote {
  id           String   @id @default(uuid())
  trackId      String
  userId       String
  vote         Int
  contextId    String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([userId])
}

model TrackNote {
  id        String   @id @default(uuid())
  trackId   String
  userId    String
  note      String?  @db.Text
  // legacy integer rating kept for migration; new decimal rating stored in rating_decimal
  rating    Int?
  rating_decimal Decimal? @db.Decimal(4,2)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([userId])
}

model TrackNoteLatest {
  trackId   String
  userId    String
  rating    Decimal? @db.Decimal(4,2)
  note      String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([trackId, userId])
  @@index([trackId])
  @@index([userId])
}

model PlaylistEntry {
  id            String   @id @default(uuid())
  playlistId    String
  trackId       String
  addedByUserId String?
  addedAt       DateTime @default(now()) @db.Timestamptz(6)
  position      Int?
  metadata      Json?    @db.Json

  track         Track?   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  addedBy       User?    @relation(fields: [addedByUserId], references: [id], onDelete: Cascade)

  // Relacionamento com Playlist gerenciada
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([addedByUserId])
}

// =====================
// Spotify management models
// =====================

model Playlist {
  id         String   @id @default(uuid())
  name       String
  description String?
  spotifyId  String?  // optional external Spotify playlist id
  accountId  String?  // FK to SpotifyAccount when tied to a bot account
  coverUrl   String?
  isManaged  Boolean  @default(true)
  meta       Json?    @db.Json
  syncedAt   DateTime? @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  // relations
  entries    PlaylistEntry[]
  account    SpotifyAccount? @relation(fields: [accountId], references: [id])
  liveRequests LiveRequest[]
  syncLogs     PlaylistSyncLog[]
  groupChats   GroupChat[]

  @@index([accountId])
}

model LiveRequest {
  id                 String   @id @default(uuid())
  trackId            String?  // FK to Track (if resolved)
  userId             String?  // who requested (User.id)
  playlistId         String?  // optional target playlist
  status             String   @default("pending") // pending | approved | played | rejected
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  handledBySessionId String?
  handledAt          DateTime? @db.Timestamptz(6)
  metadata           Json?    @db.Json
  archivedAt         DateTime? @db.Timestamptz(6)

  // relations
  track    Track?   @relation(fields: [trackId], references: [id], onDelete: SetNull)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  playlist Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
}



model PlaylistSyncLog {
  id          String   @id @default(uuid())
  playlistId  String
  attemptedBy String?  // user id who triggered sync
  startedAt   DateTime @default(now()) @db.Timestamptz(6)
  finishedAt  DateTime? @db.Timestamptz(6)
  success     Boolean? @default(false)
  result      Json?    @db.Json
  errorMessage String?

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([startedAt])
}

// Temporary OAuth session records for frontend-initiated Spotify auth flows
model SpotifyAuthSession {
  id            String   @id @default(uuid())
  state         String   @unique
  userId        String?  // optional: the local User.id this auth is intended for
  accountId     String?  // optional: SpotifyAccount.id if already known
  redirectAfter String?  // optional URL or route to redirect after auth
  used          Boolean  @default(false)
  metadata      Json?    @db.Json
  expiresAt     DateTime?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([accountId])
}

// Global Spotify rate limit state (singleton table)
model SpotifyRateLimit {
  id              Int      @id @default(1) // Always 1 (singleton)
  blockedUntil    DateTime? @db.Timestamptz(6)
  retryAfterHeader String?
  lastUpdated     DateTime @default(now()) @db.Timestamptz(6)
  
  @@map("SpotifyRateLimit")
}

// Listening sessions - groups playbacks into temporal sessions
model ListeningSession {
  id         String   @id @default(uuid())
  userId     String
  startedAt  DateTime @db.Timestamptz(6)
  endedAt    DateTime? @db.Timestamptz(6)
  trackCount Int      @default(0)
  totalMs    BigInt   @default(0) @db.BigInt
  deviceType String?
  contextType String?
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbacks  TrackPlayback[]
  
  @@index([userId, startedAt])
}

// Pre-computed yearly summary for Wrapped
model UserYearSummary {
  id            String   @id @default(uuid())
  userId        String
  year          Int
  
  // Totals
  totalMinutes  Int
  totalPlays    Int
  uniqueTracks  Int
  uniqueArtists Int
  uniqueAlbums  Int
  
  // Top lists (JSON arrays)
  topTracks     Json?    @db.Json
  topArtists    Json?    @db.Json
  topGenres     Json?    @db.Json
  topAlbums     Json?    @db.Json
  
  // Temporal patterns
  hourlyPattern Json?    @db.Json
  weekdayPattern Json?   @db.Json
  monthlyPattern Json?   @db.Json
  
  // Audio personality
  avgDanceability Float?
  avgEnergy       Float?
  avgValence      Float?
  avgTempo        Float?
  
  // Discoveries
  newArtistsCount Int?
  newTracksCount  Int?
  topDiscoveries  Json?    @db.Json
  
  // Listening behavior
  skipRate        Float?
  repeatRate      Float?
  avgSessionMinutes Float?
  longestStreak   Json?    @db.Json
  
  computedAt    DateTime @default(now()) @db.Timestamptz(6)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, year])
  @@index([year])
}

// MenuState - stores navigation state for interactive menu flows
model MenuState {
  id        String   @id @default(uuid())
  userId    String   // WhatsApp user identifier (e.g., 5581...@c.us)
  flowId    String   // Flow identifier (e.g., 'spotify', 'dogfort')
  path      String   // Current path in flow tree (e.g., '/historico/mensal')
  history   Json?    @db.Json // Array of previous paths for back navigation
  context   Json?    @db.Json // Additional flow-specific data
  expiresAt DateTime? @db.Timestamptz(6) // TTL for cleanup
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([userId, flowId])
  @@index([expiresAt])
  @@map("MenuState")
}

// =====================
// Collaborative Group Listening
// =====================

model GroupChat {
  id              String   @id @default(uuid())
  chatId          String   @unique // WhatsApp group ID
  name            String?
  playlistId      String?  // Associated shared playlist
  isActive        Boolean  @default(true)
  settings        Json?    @db.Json // voting thresholds, etc.
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  playlist        Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  votes           CollaborativeVote[]

  @@index([chatId])
  @@index([playlistId])
}

model CollaborativeVote {
  id              String   @id @default(uuid())
  groupChatId     String
  pollId          String?  // FK to Poll if using poll system
  voteType        String   // 'skip' | 'add'
  trackId         String?  // Track being voted on
  trackName       String?
  trackArtists    String?
  initiatorUserId String   // Who started the vote
  targetUserIds   Json     @db.Json // Array of user IDs eligible to vote
  votesFor        Json     @db.Json // Array of user IDs who voted yes
  votesAgainst    Json     @db.Json // Array of user IDs who voted no
  status          String   @default("active") // active | passed | failed | expired
  threshold       Float    @default(0.5) // Percentage needed (0.5 = 50%)
  processed       Boolean  @default(false) // Flag to prevent duplicate resolution actions
  expiresAt       DateTime? @db.Timestamptz(6)
  resolvedAt      DateTime? @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)

  groupChat       GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
  poll            Poll?     @relation(fields: [pollId], references: [id], onDelete: SetNull)

  @@index([groupChatId, status])
  @@index([pollId])
  @@index([expiresAt])
  @@index([status, processed])
}

// === Jam/Radio Session Models ===

// Jam/Radio session where a host broadcasts their playback to listeners
model JamSession {
  id                String    @id @default(uuid())
  hostUserId        String    // Creator/broadcaster of the jam
  isActive          Boolean   @default(true)
  jamType           String    @default("classic") // "classic" or "collaborative"
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  
  // Current playback state
  currentTrackId    String?
  currentTrackUri   String?
  currentTrackName  String?
  currentTrackAlbum String?
  currentTrackImage String?
  currentArtists    String?
  currentProgressMs Int?      // Current position in track (milliseconds)
  isPlaying         Boolean   @default(false)
  lastSyncAt        DateTime? @db.Timestamptz(6) // Last time sync was performed
  lastActiveAt      DateTime  @default(now()) @db.Timestamptz(6) // Last time host was playing
  
  // Metadata
  chatId            String?   // Group chat where jam is active
  
  // Relations
  host              User      @relation("JamHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  listeners         JamListener[]
  queue             JamQueue[]
  
  @@index([hostUserId])
  @@index([isActive])
  @@index([chatId])
}

// Queue for collaborative jams
model JamQueue {
  id           String   @id @default(uuid())
  jamId        String
  trackUri     String
  trackId      String?
  trackName    String
  trackArtists String?
  trackAlbum   String?
  trackImage   String?
  addedBy      String   // User ID who added
  position     Int      // Order in queue
  votesFor     Int      @default(0)
  votesAgainst Int      @default(0)
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  playedAt     DateTime? @db.Timestamptz(6)
  
  // Relations
  jam          JamSession @relation(fields: [jamId], references: [id], onDelete: Cascade)
  addedByUser  User       @relation("JamQueueAdder", fields: [addedBy], references: [id], onDelete: Cascade)
  
  @@index([jamId])
  @@index([addedBy])
  @@index([approved])
  @@index([position])
}

// Listeners in a jam session
model JamListener {
  id          String   @id @default(uuid())
  jamId       String
  userId      String
  joinedAt    DateTime @default(now()) @db.Timestamptz(6)
  lastSyncAt  DateTime @updatedAt @db.Timestamptz(6)
  isActive    Boolean  @default(true)
  
  // Relations
  jam         JamSession @relation(fields: [jamId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([jamId, userId])
  @@index([jamId])
  @@index([userId])
  @@index([isActive])
}
